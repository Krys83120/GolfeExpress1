generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  CLIENT
  PRO
  RIDER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum ProCategory {
  RESTAURANT
  BOULANGERIE
  BOUCHERIE
  EPICERIE
  PHARMACIE
  FLEURISTE
  LIBRAIRIE
  PARFUMERIE
  AUTRE
}

enum ProStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

enum SubscriptionType {
  FREE
  PREMIUM
  PREMIUM_PLUS
}

enum VehicleType {
  SCOOTER
  VOITURE
  VELO
  ELECTRIQUE
}

enum RiderStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  RIDER_ASSIGNED
  PICKED_UP
  IN_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum EarningType {
  DELIVERY_FEE
  TIP
  BONUS
  INCENTIVE
}

enum EarningStatus {
  PENDING
  AVAILABLE
  PAID
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationType {
  ORDER_STATUS
  NEW_ORDER
  RIDER_NEARBY
  PROMO
  SYSTEM
  PAYMENT
}

// ==================== UTILISATEURS ====================

// NOTE IMPORTANT — Intégration Supabase Auth :
// `id` n'est PAS généré par Prisma (pas de @default(uuid())). Il est fourni
// explicitement et correspond toujours à `auth.users.id` côté Supabase.
// La ligne User est créée automatiquement par un trigger SQL Postgres
// (voir supabase/migrations) à chaque INSERT dans auth.users — donc Prisma
// ne doit JAMAIS créer de User directement via `prisma.user.create()` sans
// id explicite : la création du compte passe par Supabase Auth (signUp),
// le trigger se charge de la ligne User correspondante.
// `passwordHash` n'existe plus : Supabase Auth gère les mots de passe.
model User {
  id            String    @id
  email         String    @unique
  phone         String    @unique
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  avatar        String?
  role          UserRole  @default(CLIENT)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  clientProfile   Client?
  proProfile      Pro?
  riderProfile    Rider?
  adminProfile    Admin?
  addresses       Address[]
  notifications   Notification[]
}

// ==================== CLIENT ====================

model Client {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  fidelityPoints  Int      @default(0) @map("fidelity_points")
  referralCode    String   @unique @default(uuid()) @map("referral_code")
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          Order[]
  reviews         Review[]
}

// ==================== PRO (COMMERÇANT) ====================

model Pro {
  id                String      @id @default(uuid())
  userId            String      @unique @map("user_id")
  businessName      String      @map("business_name")
  siret             String      @unique
  description       String?
  category          ProCategory
  logo              String?
  coverImage        String?     @map("cover_image")
  phone             String
  emailContact      String      @map("email_contact")
  status            ProStatus   @default(PENDING)
  commissionRate    Decimal     @default(0.15) @map("commission_rate")
  subscriptionType  SubscriptionType @default(FREE) @map("subscription_type")
  subscriptionExpiry DateTime?  @map("subscription_expiry")
  rating            Decimal?    @db.Decimal(2,1)
  ratingCount       Int         @default(0) @map("rating_count")
  createdAt         DateTime    @default(now()) @map("created_at")
  
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses         Address[]
  products          Product[]
  openingHours      OpeningHours[]
  deliveryZones     DeliveryZone[]
  orders            Order[]
  reviews           Review[]
}

// ==================== LIVREUR (RIDER) ====================

model Rider {
  id              String       @id @default(uuid())
  userId          String       @unique @map("user_id")
  vehicleType     VehicleType  @map("vehicle_type")
  vehiclePlate    String?      @map("vehicle_plate")
  licenseNumber   String?      @map("license_number")
  idCardFront     String       @map("id_card_front")
  idCardBack      String       @map("id_card_back")
  iban            String
  status          RiderStatus  @default(PENDING)
  isOnline        Boolean      @default(false) @map("is_online")
  currentLat      Decimal?     @db.Decimal(10,8) @map("current_lat")
  currentLng      Decimal?     @db.Decimal(11,8) @map("current_lng")
  currentLocationUpdatedAt DateTime? @map("current_location_updated_at")
  rating          Decimal?     @db.Decimal(2,1)
  ratingCount     Int          @default(0) @map("rating_count")
  totalDeliveries Int          @default(0) @map("total_deliveries")
  totalEarnings   Decimal      @default(0) @db.Decimal(10,2) @map("total_earnings")
  balance         Decimal      @default(0) @db.Decimal(10,2)
  createdAt       DateTime     @default(now()) @map("created_at")
  
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          Order[]
  earnings        Earning[]
  withdrawals     Withdrawal[]
}

// ==================== ADRESSES ====================

model Address {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  proId       String?  @map("pro_id")
  label       String
  street      String
  complement  String?
  zipCode     String   @map("zip_code")
  city        String
  lat         Decimal  @db.Decimal(10,8)
  lng         Decimal  @db.Decimal(11,8)
  isDefault   Boolean  @default(false) @map("is_default")
  
  user        User?    @relation(fields: [userId], references: [id])
  pro         Pro?     @relation(fields: [proId], references: [id])
  ordersFrom  Order[]  @relation("OrderFromAddress")
  ordersTo    Order[]  @relation("OrderToAddress")
}

// ==================== ZONES DE LIVRAISON PRO ====================

model DeliveryZone {
  id          String   @id @default(uuid())
  proId       String   @map("pro_id")
  name        String
  geoJson     Json     @map("geo_json")
  minOrder    Decimal? @db.Decimal(6,2) @map("min_order")
  deliveryFee Decimal  @db.Decimal(4,2) @map("delivery_fee")
  estimatedTime Int    @map("estimated_time")
  isActive    Boolean  @default(true) @map("is_active")
  
  pro         Pro      @relation(fields: [proId], references: [id])
}

// ==================== PRODUITS ====================

model Product {
  id          String   @id @default(uuid())
  proId       String   @map("pro_id")
  name        String
  description String?
  price       Decimal  @db.Decimal(8,2)
  image       String?
  category    String
  isAvailable Boolean  @default(true) @map("is_available")
  isFeatured  Boolean  @default(false) @map("is_featured")
  options     ProductOption[]
  
  pro         Pro      @relation(fields: [proId], references: [id])
  orderItems  OrderItem[]
}

model ProductOption {
  id          String        @id @default(uuid())
  productId   String        @map("product_id")
  name        String
  isRequired  Boolean       @default(false) @map("is_required")
  isMultiple  Boolean       @default(false) @map("is_multiple")
  choices     OptionChoice[]
  
  product     Product       @relation(fields: [productId], references: [id])
}

model OptionChoice {
  id            String        @id @default(uuid())
  optionId      String        @map("option_id")
  name          String
  priceModifier Decimal       @default(0) @db.Decimal(6,2) @map("price_modifier")
  
  option        ProductOption @relation(fields: [optionId], references: [id])
}

// ==================== COMMANDES ====================

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique @map("order_number")
  clientId        String      @map("client_id")
  proId           String      @map("pro_id")
  riderId         String?     @map("rider_id")
  fromAddressId   String      @map("from_address_id")
  toAddressId     String      @map("to_address_id")
  
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  
  subtotal        Decimal     @db.Decimal(10,2)
  deliveryFee     Decimal     @db.Decimal(6,2) @map("delivery_fee")
  serviceFee      Decimal     @db.Decimal(6,2) @map("service_fee")
  discount        Decimal     @default(0) @db.Decimal(10,2)
  total           Decimal     @db.Decimal(10,2)
  
  proEarnings     Decimal     @db.Decimal(10,2) @map("pro_earnings")
  riderEarnings   Decimal     @db.Decimal(6,2) @map("rider_earnings")
  platformEarnings Decimal    @db.Decimal(10,2) @map("platform_earnings")
  
  placedAt        DateTime    @default(now()) @map("placed_at")
  acceptedAt      DateTime?   @map("accepted_at")
  readyAt         DateTime?   @map("ready_at")
  pickedUpAt      DateTime?   @map("picked_up_at")
  deliveredAt     DateTime?   @map("delivered_at")
  estimatedDelivery DateTime? @map("estimated_delivery")
  
  clientNote      String?     @map("client_note")
  deliveryPhoto   String?     @map("delivery_photo")
  deliveryCode    String?     @map("delivery_code")
  rating          Int?
  review          String?
  
  client          Client      @relation(fields: [clientId], references: [id])
  pro             Pro         @relation(fields: [proId], references: [id])
  rider           Rider?      @relation(fields: [riderId], references: [id])
  fromAddress     Address     @relation("OrderFromAddress", fields: [fromAddressId], references: [id])
  toAddress       Address     @relation("OrderToAddress", fields: [toAddressId], references: [id])
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  trackingEvents  TrackingEvent[]
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  productId   String   @map("product_id")
  productName String   @map("product_name")
  quantity    Int
  unitPrice   Decimal  @db.Decimal(8,2) @map("unit_price")
  totalPrice  Decimal  @db.Decimal(10,2) @map("total_price")
  options     Json?
  
  order       Order    @relation(fields: [orderId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}

model OrderStatusHistory {
  id          String      @id @default(uuid())
  orderId     String      @map("order_id")
  status      OrderStatus
  changedAt   DateTime    @default(now()) @map("changed_at")
  changedBy   String?     @map("changed_by")
  note        String?
  
  order       Order       @relation(fields: [orderId], references: [id])
}

// ==================== SUIVI GPS ====================

model TrackingEvent {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  riderId   String   @map("rider_id")
  lat       Decimal  @db.Decimal(10,8)
  lng       Decimal  @db.Decimal(11,8)
  timestamp DateTime @default(now())
  
  order     Order    @relation(fields: [orderId], references: [id])
}

// ==================== GAIN LIVREUR ====================

model Earning {
  id          String      @id @default(uuid())
  riderId     String      @map("rider_id")
  orderId     String      @map("order_id")
  amount      Decimal     @db.Decimal(8,2)
  type        EarningType
  status      EarningStatus @default(PENDING)
  createdAt   DateTime    @default(now()) @map("created_at")
  paidAt      DateTime?   @map("paid_at")
  
  rider       Rider       @relation(fields: [riderId], references: [id])
}

model Withdrawal {
  id          String   @id @default(uuid())
  riderId     String   @map("rider_id")
  amount      Decimal  @db.Decimal(8,2)
  status      WithdrawalStatus @default(PENDING)
  iban        String
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  rider       Rider    @relation(fields: [riderId], references: [id])
}

// ==================== PARAMÈTRES ADMIN ====================

model GlobalSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String   @map("updated_by")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== ADMIN ====================

model Admin {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  permissions Json
  department  String?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== HORAIRES D'OUVERTURE ====================

model OpeningHours {
  id        String   @id @default(uuid())
  proId     String   @map("pro_id")
  dayOfWeek Int      @map("day_of_week")
  openTime  String   @map("open_time")
  closeTime String   @map("close_time")
  isClosed  Boolean  @default(false) @map("is_closed")
  
  pro       Pro      @relation(fields: [proId], references: [id])
}

// ==================== AVIS ====================

model Review {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  proId       String?  @map("pro_id")
  riderId     String?  @map("rider_id")
  orderId     String   @map("order_id")
  rating      Int
  comment     String?
  isVisible   Boolean  @default(true) @map("is_visible")
  createdAt   DateTime @default(now()) @map("created_at")
  
  client      Client   @relation(fields: [clientId], references: [id])
  pro         Pro?     @relation(fields: [proId], references: [id])
}
