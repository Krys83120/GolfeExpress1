# ==================== SUPABASE ====================
# Récupérables dans Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# Clé service_role — NE JAMAIS exposer côté client, utilisée uniquement côté serveur
# (création d'utilisateurs admin, bypass RLS pour les opérations système, trigger sync)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ==================== BASE DE DONNÉES (Prisma) ====================
# Connection string Supabase Postgres "Transaction" (pooler, port 6543) — pour Prisma Client en prod/serverless
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Connection string "Session" (port 5432, direct) — requise par Prisma Migrate (DDL)
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ==================== STRIPE ====================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==================== APPLICATION ====================
# URL publique de l'API (utile pour générer des liens absolus, ex: emails)
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Environnement ("development" | "production")
NODE_ENV="development"
